{
  "seed": 42,
  "model": {
    "arch": "wrn28_8",
    "drop_path_rate": 0.1
  },
  "data": {
    "train_labeled": "food11/training/labeled",
    "train_unlabeled": "food11/training/unlabeled",
    "valid": "food11/validation",
    "test": "food11/testing"
  },
  "dataloader": {
    "batch_size": 32,
    "num_workers": 8,
    "pin_memory": true
  },
  "image": {
    "img_size": 224,
    "mean": [0.485, 0.456, 0.406],
    "std": [0.229, 0.224, 0.225]
  },
  "augment": {
    "random_resized_crop_scale": [0.4, 1.0],
    "random_resized_crop_ratio": [0.9, 1.1],
    "horizontal_flip_p": 0.5,
    "rotation_deg": 20,
    "color_jitter": {
      "brightness": 0.4,
      "contrast": 0.4,
      "saturation": 0.4,
      "hue": 0.1
    },
    "grayscale_p": 0.1,
    "random_erasing": {
      "p": 0.4,
      "scale": [0.02, 0.2]
    }
  },
  "train": {
    "n_epochs": 200,
    "lr": 0.0003,
    "weight_decay": 0.001,
    "label_smoothing": 0.1,
    "dropout": 0.3,
    "accum_steps": 2,
    "scheduler": "onecycle",
    "max_lr": 0.001,
    "use_amp": true,
    "mix": {
      "enabled": true,
      "alpha": 1.0,
      "mode": "cutmix",
      "_comment": "mode can be 'mixup' or 'cutmix'"
    }
  },
  "tta": {
    "enabled": true,
    "num_augments": 10
  },
  "swa": {
    "enabled": true,
    "start_epoch_ratio": 0.9,
    "lr": 1e-5
  },
  "semi": {
    "enabled": true,
    "warmup_epochs": 8,
    "pseudo_threshold": 0.95,
    "pseudo_threshold_end": 0.80,
    "unsup_batch_size": 64,
    "lambda_u": 0.5,
    "lambda_u_ramp_epochs": 30,
    "randaugment_num_ops": 2,
    "randaugment_magnitude": 12,
    "ema": {
      "decay": 0.995
    }
  },
  "output": {
    "best_path": "best-model.pt",
    "predict_path": "predict.csv"
  }
}
