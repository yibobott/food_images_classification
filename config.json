{
  "seed": 42,
  "data": {
    "train_labeled": "food11/training/labeled",
    "train_unlabeled": "food11/training/unlabeled",
    "valid": "food11/validation",
    "test": "food11/testing"
  },
  "dataloader": {
    "batch_size": 64,
    "num_workers": 8,
    "pin_memory": true
  },
  "image": {
    "img_size": 128,
    "mean": [0.485, 0.456, 0.406],
    "std": [0.229, 0.224, 0.225]
  },
  "augment": {
    "random_resized_crop_scale": [0.8, 1.0],
    "random_resized_crop_ratio": [0.95, 1.05],
    "horizontal_flip_p": 0.5,
    "rotation_deg": 5,
    "color_jitter": {
      "brightness": 0.2,
      "contrast": 0.2,
      "saturation": 0.2,
      "hue": 0.05
    }
  },
  "train": {
    "n_epochs": 200,
    "lr": 0.001,
    "weight_decay": 0.0001,
    "label_smoothing": 0.05
  },
  "semi": {
    "enabled": true,
    "warmup_epochs": 20,
    "pseudo_threshold": 0.95,
    "unsup_batch_size": 128,
    "lambda_u": 0.5,
    "ema": {
      "decay": 0.999
    }
  },
  "output": {
    "best_path": "best-model.pt",
    "predict_path": "predict.csv"
  }
}
