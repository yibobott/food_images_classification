{
  "seed": 42,
  "data": {
    "train_labeled": "food11/training/labeled",
    "train_unlabeled": "food11/training/unlabeled",
    "valid": "food11/validation",
    "test": "food11/testing"
  },
  "dataloader": {
    "batch_size": 64,
    "num_workers": 8,
    "pin_memory": true
  },
  "image": {
    "img_size": 128,
    "mean": [0.485, 0.456, 0.406],
    "std": [0.229, 0.224, 0.225]
  },
  "augment": {
    "random_resized_crop_scale": [0.7, 1.0],
    "random_resized_crop_ratio": [0.9, 1.1],
    "horizontal_flip_p": 0.5,
    "rotation_deg": 10,
    "color_jitter": {
      "brightness": 0.25,
      "contrast": 0.25,
      "saturation": 0.25,
      "hue": 0.05
    }
  },
  "train": {
    "n_epochs": 300,
    "lr": 0.0007,
    "weight_decay": 0.0002,
    "label_smoothing": 0.05,
    "mix": {
      "enabled": true,
      "alpha": 0.2,
      "mode": "mixup",
      "_comment": "mode can be 'mixup' or 'cutmix'"
    }
  },
  "semi": {
    "enabled": true,
    "warmup_epochs": 8,
    "pseudo_threshold": 0.92,
    "unsup_batch_size": 128,
    "lambda_u": 0.4,
    "lambda_u_ramp_epochs": 30,
    "randaugment_num_ops": 2,
    "randaugment_magnitude": 9,
    "ema": {
      "decay": 0.999
    }
  },
  "output": {
    "best_path": "best-model.pt",
    "predict_path": "predict.csv"
  }
}
